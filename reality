#!/bin/bash
# Xray VLESS + REALITY 一键安装脚本 (针对特定输出格式修复版)

set -e

# --- 颜色定义 ---
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
PLAIN='\033[0m'

# 获取本机公网 IP
SERVER_IP=$(curl -s https://api.ipify.org || echo "你的服务器IP")

echo -e "${BLUE}开始安装 Xray VLESS + REALITY...${PLAIN}"

# 1. 更新系统
echo -e "${GREEN}正在更新系统软件包...${PLAIN}"
sudo apt update && sudo apt upgrade -y

# 2. 安装 Xray
echo -e "${GREEN}正在下载并安装 Xray 官方脚本...${PLAIN}"
bash <(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh) install

# 3. 生成配置所需参数
echo -e "${GREEN}正在生成密钥对和 UUID...${PLAIN}"

XRAY_BIN="/usr/local/bin/xray"
# 生成密钥
KEYS=$($XRAY_BIN x25519)

# --- 核心修复：根据你提供的格式提取 ---
# 格式: PrivateKey: XXX Password: YYY Hash32: ZZZ
PRIVATE_KEY=$(echo "$KEYS" | awk -F'PrivateKey: ' '{print $2}' | awk '{print $1}')
PUBLIC_KEY=$(echo "$KEYS" | awk -F'Password: ' '{print $2}' | awk '{print $1}')
UUID=$(cat /proc/sys/kernel/random/uuid)
DEST_DOMAIN="www.apple.com"

# 检查是否提取成功
if [ -z "$PRIVATE_KEY" ] || [ -z "$PUBLIC_KEY" ]; then
  echo -e "${RED}错误: 无法解析密钥串！${PLAIN}"
  echo -e "原始输出为: $KEYS"
  exit 1
fi

# 4. 写入服务端配置文件
echo -e "${GREEN}正在配置服务端 config.json...${PLAIN}"
cat <<EOF >/usr/local/etc/xray/config.json
{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
  },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "$UUID",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "$DEST_DOMAIN:443",
          "serverNames": ["$DEST_DOMAIN"],
          "privateKey": "$PRIVATE_KEY",
          "shortIds": [""]
        }
      }
    }
  ],
  "outbounds": [
    { "tag": "direct", "protocol": "freedom", "settings": {} },
    { "tag": "block", "protocol": "blackhole", "settings": {} }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      { "type": "field", "ip": ["geoip:private"], "outboundTag": "block" },
      { "type": "field", "ip": ["geoip:cn"], "outboundTag": "block" }
    ]
  }
}
EOF

# 5. 生成客户端配置文件 (client_config.json)
echo -e "${GREEN}正在生成客户端配置文件...${PLAIN}"
cat <<EOF >./client_config.json
{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks",
      "settings": { "udp": true },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "$SERVER_IP",
            "port": 443,
            "users": [
              {
                "id": "$UUID",
                "flow": "xtls-rprx-vision",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "$DEST_DOMAIN",
          "publicKey": "$PUBLIC_KEY",
          "shortId": ""
        }
      }
    },
    { "tag": "direct", "protocol": "freedom", "settings": {} }
  ]
}
EOF

# 6. 重启服务
sudo systemctl enable xray
sudo systemctl restart xray

# 7. 最终展示
clear
echo -e "${BLUE}======================================${PLAIN}"
echo -e "${GREEN}  Xray 安装成功 (密钥提取已修复)！${PLAIN}"
echo -e "${BLUE}======================================${PLAIN}"
echo -e "Server IP:    ${RED}$SERVER_IP${PLAIN}"
echo -e "UUID:         ${RED}$UUID${PLAIN}"
echo -e "Public Key:   ${RED}$PUBLIC_KEY${PLAIN}"
echo -e "Private Key:  $PRIVATE_KEY"
echo -e "${BLUE}======================================${PLAIN}"
echo -e "客户端配置已保存到: ${GREEN}$(pwd)/client_config.json${PLAIN}"
